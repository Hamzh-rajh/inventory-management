<%- include('../partials/header') %>

<div class="d-flex justify-content-end mb-4">
  <a href="/warehouses/new" class="btn btn-primary"><i class="bi bi-plus-lg"></i> إضافة مخزن</a>
</div>

<div class="row g-4">
  <% warehouses.forEach(w => { %>
  <div class="col-12 col-md-6">
    <div class="stat-card">
      <div class="d-flex align-items-start justify-content-between">
        <div>
          <h5 class="fw-bold mb-1"><i class="bi bi-building me-2 text-primary"></i><%= w.name %></h5>
          <div class="text-muted small"><i class="bi bi-geo-alt me-1"></i><%= w.location || 'غير محدد' %></div>
        </div>
        <a href="/warehouses/<%= w.id %>/edit" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
      </div>
    </div>
  </div>
  <% }) %>
</div>

<%- include('../partials/footer') %>
