<%- include('../partials/header') %>

<div class="d-flex justify-content-end mb-4">
  <a href="/transfers/new" class="btn btn-primary"><i class="bi bi-plus-lg"></i> تحويل جديد</a>
</div>

<div class="table-card">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead>
        <tr><th>المنتج</th><th>من</th><th>إلى</th><th>الكمية</th><th>ملاحظات</th><th>التاريخ</th></tr>
      </thead>
      <tbody>
        <% if (transfers.length === 0) { %>
        <tr><td colspan="6" class="text-center py-4 text-muted">لا توجد تحويلات</td></tr>
        <% } %>
        <% transfers.forEach(t => { %>
        <tr>
          <td><strong><%= t.product_name %></strong><br><small class="text-muted"><%= t.code %></small></td>
          <td><span class="badge bg-secondary"><%= t.from_name %></span></td>
          <td><span class="badge bg-primary"><%= t.to_name %></span></td>
          <td><%= t.quantity %></td>
          <td><%= t.notes || '-' %></td>
          <td><small><%= new Date(t.created_at).toLocaleDateString('ar-SA') %></small></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>
