<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-12 col-lg-7">
    <div class="form-card">
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger"><i class="bi bi-exclamation-circle me-2"></i><%= error %></div>
      <% } %>
      <form method="POST" action="/transfers">
        <div class="row g-3">
          <div class="col-12">
            <label class="form-label">المنتج <span class="text-danger">*</span></label>
            <select name="product_id" class="form-select" required>
              <option value="">اختر منتج...</option>
              <% 
              const seen = new Set();
              products.forEach(p => {
                if (!seen.has(p.id)) {
                  seen.add(p.id);
              %>
              <option value="<%= p.id %>"><%= p.name %> (<%= p.code %>)</option>
              <%   }
              }) %>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label">من المخزن <span class="text-danger">*</span></label>
            <select name="from_warehouse_id" class="form-select" required>
              <% warehouses.forEach(w => { %>
              <option value="<%= w.id %>"><%= w.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label">إلى المخزن <span class="text-danger">*</span></label>
            <select name="to_warehouse_id" class="form-select" required>
              <% warehouses.forEach(w => { %>
              <option value="<%= w.id %>"><%= w.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label">الكمية <span class="text-danger">*</span></label>
            <input type="number" name="quantity" class="form-control" min="1" value="1" required>
          </div>
          <div class="col-12">
            <label class="form-label">ملاحظات</label>
            <input type="text" name="notes" class="form-control" placeholder="اختياري...">
          </div>
        </div>
        <div class="d-flex gap-2 mt-4">
          <button type="submit" class="btn btn-primary"><i class="bi bi-arrow-left-right me-1"></i>تنفيذ التحويل</button>
          <a href="/transfers" class="btn btn-outline-secondary">إلغاء</a>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
