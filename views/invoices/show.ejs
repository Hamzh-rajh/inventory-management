<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4 no-print">
  <a href="/invoices" class="btn btn-outline-secondary"><i class="bi bi-arrow-right me-1"></i>العودة</a>
  <div class="d-flex gap-2">
    <button class="btn btn-outline-primary" onclick="window.print()"><i class="bi bi-printer me-1"></i>طباعة</button>
  </div>
</div>

<div class="row justify-content-center">
  <div class="col-12 col-lg-9">
    <div class="form-card">
      <!-- Invoice header -->
      <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
          <h4 class="fw-bold mb-1">فاتورة <%= invoice.invoice_number %></h4>
          <div class="text-muted small"><%= new Date(invoice.created_at).toLocaleString('ar-SA') %></div>
          <div class="mt-2">
            <span class="badge badge-<%= invoice.type %> me-1"><%= invoice.type === 'cash' ? 'نقدي' : 'آجل' %></span>
            <span class="badge badge-<%= invoice.status %>"><%= invoice.status === 'paid' ? 'مدفوع' : invoice.status === 'partial' ? 'دفع جزئي' : 'غير مدفوع' %></span>
          </div>
        </div>
        <div class="text-end">
          <div class="text-muted small">المخزن</div>
          <div class="fw-bold"><%= invoice.warehouse_name %></div>
          <% if (invoice.customer_name) { %>
          <div class="mt-2 text-muted small">العميل</div>
          <div class="fw-bold"><%= invoice.customer_name %></div>
          <% if (invoice.customer_phone) { %><div class="text-muted small"><%= invoice.customer_phone %></div><% } %>
          <% } %>
        </div>
      </div>

      <!-- Items table -->
      <div class="table-responsive mb-4">
        <table class="table">
          <thead class="table-light">
            <tr><th>#</th><th>المنتج</th><th>الكود</th><th>الوحدة</th><th>الكمية</th><th>السعر</th><th>الإجمالي</th></tr>
          </thead>
          <tbody>
            <% items.forEach((item, idx) => { %>
            <tr>
              <td><%= idx + 1 %></td>
              <td><strong><%= item.product_name %></strong></td>
              <td><code><%= item.code %></code></td>
              <td><%= item.unit %></td>
              <td><%= item.quantity %></td>
              <td><%= parseFloat(item.price).toFixed(2) %></td>
              <td><strong><%= (item.quantity * item.price).toFixed(2) %></strong></td>
            </tr>
            <% }) %>
          </tbody>
          <tfoot>
            <tr class="table-light">
              <td colspan="6" class="text-end fw-bold">الإجمالي:</td>
              <td class="fw-bold fs-5"><%= invoice.total.toFixed(2) %></td>
            </tr>
            <tr>
              <td colspan="6" class="text-end text-success">المدفوع:</td>
              <td class="text-success"><%= invoice.paid.toFixed(2) %></td>
            </tr>
            <% if (invoice.total - invoice.paid > 0) { %>
            <tr>
              <td colspan="6" class="text-end text-danger">المتبقي:</td>
              <td class="text-danger fw-bold"><%= (invoice.total - invoice.paid).toFixed(2) %></td>
            </tr>
            <% } %>
          </tfoot>
        </table>
      </div>

      <% if (invoice.notes) { %>
      <div class="alert alert-light"><strong>ملاحظات:</strong> <%= invoice.notes %></div>
      <% } %>

      <!-- Payment form -->
      <% if (invoice.status !== 'paid') { %>
      <div class="border-top pt-3 no-print">
        <h6 class="mb-3"><i class="bi bi-cash-coin me-2"></i>تسجيل دفعة</h6>
        <form method="POST" action="/invoices/<%= invoice.id %>/pay" class="d-flex gap-2 align-items-end">
          <div>
            <label class="form-label small">المبلغ</label>
            <input type="number" step="0.01" name="amount" class="form-control" 
              value="<%= (invoice.total - invoice.paid).toFixed(2) %>" style="width:160px" required>
          </div>
          <button class="btn btn-success"><i class="bi bi-check-lg me-1"></i>تسجيل الدفع</button>
        </form>
      </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
