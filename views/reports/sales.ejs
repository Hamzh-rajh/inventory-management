<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4 no-print">
  <form class="d-flex gap-2 align-items-end">
    <div>
      <label class="form-label small mb-1">من تاريخ</label>
      <input type="date" name="from" class="form-control form-control-sm" value="<%= from %>">
    </div>
    <div>
      <label class="form-label small mb-1">إلى تاريخ</label>
      <input type="date" name="to" class="form-control form-control-sm" value="<%= to %>">
    </div>
    <button class="btn btn-primary btn-sm">تطبيق</button>
    <a href="/reports/sales" class="btn btn-outline-secondary btn-sm">إعادة</a>
  </form>
  <button class="btn btn-outline-primary" onclick="window.print()"><i class="bi bi-printer me-1"></i>طباعة</button>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-md-3">
    <div class="stat-card text-center">
      <div class="text-muted small">عدد الفواتير</div>
      <div class="fw-bold fs-4"><%= invoices.length %></div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card text-center">
      <div class="text-muted small">إجمالي المبيعات</div>
      <div class="fw-bold fs-5"><%= totalSales.toFixed(2) %></div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card text-center">
      <div class="text-muted small">المحصل</div>
      <div class="fw-bold fs-5 text-success"><%= totalPaid.toFixed(2) %></div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card text-center">
      <div class="text-muted small">المتبقي</div>
      <div class="fw-bold fs-5 text-danger"><%= totalUnpaid.toFixed(2) %></div>
    </div>
  </div>
</div>

<div class="row g-4">
  <div class="col-12 col-lg-7">
    <div class="table-card">
      <div class="p-3 border-bottom"><strong>الفواتير</strong></div>
      <div class="table-responsive">
        <table class="table table-sm mb-0">
          <thead><tr><th>رقم الفاتورة</th><th>النوع</th><th>العميل</th><th>الإجمالي</th><th>الحالة</th><th>التاريخ</th></tr></thead>
          <tbody>
            <% if (invoices.length === 0) { %>
            <tr><td colspan="6" class="text-center py-3 text-muted">لا توجد فواتير</td></tr>
            <% } %>
            <% invoices.forEach(i => { %>
            <tr>
              <td><a href="/invoices/<%= i.id %>" class="text-decoration-none"><%= i.invoice_number %></a></td>
              <td><span class="badge badge-<%= i.type %>"><%= i.type === 'cash' ? 'نقدي' : 'آجل' %></span></td>
              <td><%= i.customer_name || '-' %></td>
              <td><strong><%= i.total.toFixed(2) %></strong></td>
              <td><span class="badge badge-<%= i.status %>"><%= i.status === 'paid' ? 'مدفوع' : i.status === 'partial' ? 'جزئي' : 'غير مدفوع' %></span></td>
              <td><small><%= new Date(i.created_at).toLocaleDateString('ar-SA') %></small></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="col-12 col-lg-5">
    <div class="table-card">
      <div class="p-3 border-bottom"><strong><i class="bi bi-trophy me-2"></i>أكثر المنتجات مبيعاً</strong></div>
      <div class="table-responsive">
        <table class="table table-sm mb-0">
          <thead><tr><th>#</th><th>المنتج</th><th>الكمية</th><th>الإيراد</th></tr></thead>
          <tbody>
            <% if (topProducts.length === 0) { %>
            <tr><td colspan="4" class="text-center py-3 text-muted">لا توجد بيانات</td></tr>
            <% } %>
            <% topProducts.forEach((p, i) => { %>
            <tr>
              <td><strong><%= i+1 %></strong></td>
              <td><%= p.name %></td>
              <td><span class="badge bg-primary"><%= p.total_sold %></span></td>
              <td><strong><%= p.revenue.toFixed(2) %></strong></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
