<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-12 col-lg-8">
    <div class="form-card">
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger"><i class="bi bi-exclamation-circle me-2"></i><%= error %></div>
      <% } %>

      <form method="POST" action="<%= product ? `/products/${product.id}?_method=PUT` : '/products' %>">
        <div class="row g-3">
          <div class="col-md-4">
            <label class="form-label">الكود <span class="text-danger">*</span></label>
            <input type="text" name="code" class="form-control" required value="<%= product?.code || '' %>" placeholder="P001">
          </div>
          <div class="col-md-8">
            <label class="form-label">اسم المنتج <span class="text-danger">*</span></label>
            <input type="text" name="name" class="form-control" required value="<%= product?.name || '' %>">
          </div>
          <div class="col-12">
            <label class="form-label">الوصف</label>
            <input type="text" name="description" class="form-control" value="<%= product?.description || '' %>">
          </div>
          <div class="col-md-4">
            <label class="form-label">وحدة القياس</label>
            <select name="unit" class="form-select">
              <% ['قطعة','كيلو','لتر','متر','صندوق','كرتون','طن','دزينة'].forEach(u => { %>
              <option value="<%= u %>" <%= (product?.unit || 'قطعة') === u ? 'selected' : '' %>><%= u %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-4">
            <label class="form-label">سعر الشراء</label>
            <input type="number" step="0.01" name="purchase_price" class="form-control" value="<%= product?.purchase_price || 0 %>">
          </div>
          <div class="col-md-4">
            <label class="form-label">سعر البيع</label>
            <input type="number" step="0.01" name="sell_price" class="form-control" value="<%= product?.sell_price || 0 %>">
          </div>
          <div class="col-md-4">
            <label class="form-label">الحد الأدنى للتنبيه</label>
            <input type="number" name="min_quantity" class="form-control" value="<%= product?.min_quantity || 5 %>">
          </div>

          <% if (!product) { %>
          <div class="col-md-4">
            <label class="form-label">الكمية الابتدائية</label>
            <input type="number" name="initial_qty" class="form-control" value="0">
          </div>
          <% } %>
        </div>

        <% if (product && typeof stock !== 'undefined' && stock.length > 0) { %>
        <hr class="my-4">
        <h6 class="mb-3"><i class="bi bi-building me-2"></i>الكميات في المخازن</h6>
        <div class="row g-3">
          <% stock.forEach(s => { %>
          <div class="col-md-6">
            <label class="form-label"><%= s.warehouse_name %></label>
            <form method="POST" action="/products/<%= product.id %>/stock" class="d-flex gap-2">
              <input type="hidden" name="warehouse_id" value="<%= s.warehouse_id %>">
              <input type="number" name="quantity" class="form-control" value="<%= s.quantity %>">
              <button class="btn btn-outline-success btn-sm">حفظ</button>
            </form>
          </div>
          <% }) %>
        </div>
        <% } %>

        <div class="d-flex gap-2 mt-4">
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-1"></i><%= product ? 'تحديث' : 'إضافة' %>
          </button>
          <a href="/products" class="btn btn-outline-secondary">إلغاء</a>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
