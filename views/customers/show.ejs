<%- include('../partials/header') %>

<div class="row">
  <div class="col-12 col-md-4 mb-4">
    <div class="form-card">
      <h5 class="fw-bold mb-3"><%= customer.name %></h5>
      <div class="mb-2"><i class="bi bi-phone me-2 text-muted"></i><%= customer.phone || 'غير محدد' %></div>
      <div class="mb-2"><i class="bi bi-geo-alt me-2 text-muted"></i><%= customer.address || 'غير محدد' %></div>
      <hr>
      <div class="d-flex justify-content-between">
        <span>الرصيد المستحق:</span>
        <strong class="<%= customer.balance > 0 ? 'text-danger' : 'text-success' %>"><%= customer.balance.toFixed(2) %></strong>
      </div>
      <div class="mt-3">
        <a href="/customers/<%= customer.id %>/edit" class="btn btn-sm btn-outline-primary w-100">تعديل البيانات</a>
      </div>
    </div>
  </div>

  <div class="col-12 col-md-8">
    <div class="table-card">
      <div class="p-3 border-bottom"><strong>فواتير العميل (<%= invoices.length %>)</strong></div>
      <div class="table-responsive">
        <table class="table table-sm mb-0">
          <thead><tr><th>رقم الفاتورة</th><th>الإجمالي</th><th>المدفوع</th><th>الحالة</th><th>التاريخ</th></tr></thead>
          <tbody>
            <% if (invoices.length === 0) { %>
            <tr><td colspan="5" class="text-center py-3 text-muted">لا توجد فواتير</td></tr>
            <% } %>
            <% invoices.forEach(i => { %>
            <tr>
              <td><a href="/invoices/<%= i.id %>" class="text-decoration-none"><%= i.invoice_number %></a></td>
              <td><%= i.total.toFixed(2) %></td>
              <td><%= i.paid.toFixed(2) %></td>
              <td><span class="badge badge-<%= i.status %>"><%= i.status === 'paid' ? 'مدفوع' : i.status === 'partial' ? 'جزئي' : 'غير مدفوع' %></span></td>
              <td><small><%= new Date(i.created_at).toLocaleDateString('ar-SA') %></small></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
