<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-12 col-lg-6">
    <div class="form-card">
      <form method="POST" action="<%= customer ? `/customers/${customer.id}?_method=PUT` : '/customers' %>">
        <div class="row g-3">
          <div class="col-12">
            <label class="form-label">الاسم <span class="text-danger">*</span></label>
            <input type="text" name="name" class="form-control" required value="<%= customer?.name || '' %>">
          </div>
          <div class="col-md-6">
            <label class="form-label">رقم الهاتف</label>
            <input type="text" name="phone" class="form-control" value="<%= customer?.phone || '' %>">
          </div>
          <div class="col-md-6">
            <label class="form-label">العنوان</label>
            <input type="text" name="address" class="form-control" value="<%= customer?.address || '' %>">
          </div>
        </div>
        <div class="d-flex gap-2 mt-4">
          <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>حفظ</button>
          <a href="/customers" class="btn btn-outline-secondary">إلغاء</a>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
